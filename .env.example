# Auth0 Configuration (optional — app runs in demo mode without these)
# 1. Create an Auth0 SPA Application at https://manage.auth0.com
# 2. Add GitHub as a Social Connection with 'repo' scope
# 3. Set Allowed Callback URLs, Logout URLs, Web Origins to your domain

NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-client-id

# Note: GitHub PAT can also be entered directly in the app's Settings panel.
# No environment variable needed for PAT-based auth.
